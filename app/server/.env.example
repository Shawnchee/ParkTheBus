# Park The Bus — server-side secrets (NEVER commit the real .env)
# Copy to .env and fill in. The server runs fine without these (mock data +
# templated advisor), but real keys light up live odds, fixtures, and the AI.

# Google Gemini (AI advisor / MM assistant / contract summary) — free tier.
# Get a key at https://aistudio.google.com/apikey  (model: gemini-2.5-flash)
GEMINI_API_KEY=

# The Odds API — https://the-odds-api.com  (500 req/month free)
ODDS_API_KEY=

# api-football — https://www.api-football.com  (100 req/day free)
FOOTBALL_API_KEY=

PORT=8787
